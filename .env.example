# -----------------------------------------------------------------------
# lgrap — environment configuration example
# Copy this file to .env and fill in your values.
# -----------------------------------------------------------------------

# --- LLM backend (OpenAI-compatible) ---
OPENAI_BASE_URL=http://127.0.0.1:8080/v1
OPENAI_API_KEY=your-api-key-here
# Default model (used as fallback when the request does not specify one)
MODEL_NAME=gpt-4
# Comma-separated list of models the API will accept in requests
AVAILABLE_MODELS=gpt-4,gpt-3.5-turbo

# --- LangSmith monitoring ---
# New-style LANGSMITH_ vars (SDK >= 0.2) — takes precedence
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=lgrap
# Legacy aliases kept for older LangChain internals
LANGCHAIN_TRACING_V2=true

# --- Session ---
# Change this to a long random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
# Default: local SQLite file. Replace with your connection string for other backends.
# postgresql+psycopg2://user:password@host:5432/dbname
# mssql+pyodbc://user:password@dsn
DB_URL=sqlite:///./lgrap.db
